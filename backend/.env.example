# ═══════════════════════════════════════════════════════════════════════════════
# AMAN ERP — Backend Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aman
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=postgres

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# In production (with auth): redis://:password@redis:6379/0

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Admin Password ─────────────────────────────────────────────────────────────
# Generate with: python3 -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your_password'))"
ADMIN_PASSWORD_HASH=

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SYSTEM_EMAIL=admin@aman-erp.com

# ── CORS / Frontend ────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_PRODUCTION=https://erp.yourcompany.com
# Comma-separated allowed origins (overrides FRONTEND_URL_PRODUCTION when set)
ALLOWED_ORIGINS=

# ── Observability ──────────────────────────────────────────────────────────────
APP_ENV=development        # development | staging | production
SENTRY_DSN=               # Leave empty to disable Sentry
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Grafana (docker-compose only) ─────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
